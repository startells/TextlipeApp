<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Add Resources Here -->
    
        <!-- ===================== -->
    <!-- 🎨 BASE COLORS (Warm Atelier Theme) -->
    <!-- ===================== -->

    <!-- Backgrounds - Теплый кремовый, как бумага для выкроек -->
    <Color x:Key="Color.Background">#F4F6F1</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceHover">#EBEFE4</Color>

    <!-- Borders - Как натуральный лен -->
    <Color x:Key="Color.Border">#D0D9C0</Color>  
    <Color x:Key="Color.Divider">#C2CDAF</Color>

    <!-- ===================== -->
    <!-- 🧠 TEXT - Мягкий уголь, не напрягает глаза -->
    <!-- ===================== -->
    <Color x:Key="Color.TextPrimary">#1A2E1A</Color>
    <Color x:Key="Color.TextSecondary">#4A5B3A</Color>
    <Color x:Key="Color.TextMuted">#8A9A73</Color>
    <Color x:Key="Color.TextInverse">#FFFFFF</Color>

    <!-- ===================== -->
    <!-- 🪡 PRIMARY - Цвет терракоты (глина, кирпич) -->
    <!-- Используй для: Главных действий, активных состояний -->
    <!-- ===================== -->
    <Color x:Key="Color.Primary">#4A7C59</Color>
    <Color x:Key="Color.PrimaryHover">#3D664A</Color>
    <Color x:Key="Color.PrimaryActive">#2E4F38</Color>
    <Color x:Key="Color.PrimaryLight">#E6F0E6</Color>

    <!-- ===================== -->
    <!-- 🧶 SECONDARY - Оливковый/Шалфей (цвет ткани хаки) -->
    <!-- Используй для: Второстепенных действий, категорий -->
    <!-- ===================== -->
    <Color x:Key="Color.Secondary">#8DA37C</Color>
    <Color x:Key="Color.SecondaryHover">#758D64</Color>
    <Color x:Key="Color.SecondaryLight">#F0F5EB</Color>

    <!-- ===================== -->
    <!-- ✅ SUCCESS - Цвет спелого фисташки -->
    <!-- Используй для: Готовой продукции, выполненных заказов -->
    <!-- ===================== -->
    <Color x:Key="Color.Success">#8FAA6B</Color>
    <Color x:Key="Color.SuccessHover">#7A9558</Color>
    <Color x:Key="Color.SuccessLight">#EDF3E6</Color>

    <!-- ===================== -->
    <!-- ⚠️ WARNING - Горчичный/Шафран -->
    <!-- Используй для: Внимания, низких остатков, дедлайнов -->
    <!-- ===================== -->
    <Color x:Key="Color.Warning">#D4A843</Color>
    <Color x:Key="Color.WarningHover">#C29736</Color>
    <Color x:Key="Color.WarningLight">#FDF4E4</Color>

    <!-- ===================== -->
    <!-- ❌ ERROR - Тертый бордовый (не агрессивный красный) -->
    <!-- Используй для: Брака, критических ошибок -->
    <!-- ===================== -->
    <Color x:Key="Color.Error">#B85C5A</Color>
    <Color x:Key="Color.ErrorHover">#9E4947</Color>
    <Color x:Key="Color.ErrorLight">#F7E8E8</Color>

    <!-- ===================== -->
    <!-- ℹ️ INFO - Небесно-голубой, как джинса -->
    <!-- Используй для: Складских операций, информации -->
    <!-- ===================== -->
    <Color x:Key="Color.Info">#7BA4B5</Color>
    <Color x:Key="Color.InfoHover">#6691A3</Color>
    <Color x:Key="Color.InfoLight">#EAF1F4</Color>

    <!-- ===================== -->
    <!-- 🧵 ДЛЯ ШВЕЙНОЙ ТЕМАТИКИ -->
    <!-- ===================== -->
    <Color x:Key="Color.Linen">#E0E8D8</Color> 
    <Color x:Key="Color.Thimble">#C8D0B8</Color>    
    <Color x:Key="Color.TailorChalk">#D8E4C8</Color> 
    <Color x:Key="Color.Thread">#B8C8A4</Color>  
    
    <!-- Production -->
    <Color x:Key="Color.Production">#4A7C59</Color>
    <Color x:Key="Color.ProductionLight">#E6F0E6</Color>

    <!-- ThreadLight -->
    <Color x:Key="Color.ThreadLight">#E8F0E0</Color>

    <!-- Chart Colors - палитра для графиков -->
    <Color x:Key="Color.Chart1">#4A7C59</Color>   <!-- основной зеленый -->
    <Color x:Key="Color.Chart2">#8DA37C</Color>   <!-- шалфей -->
    <Color x:Key="Color.Chart3">#8FAA6B</Color>   <!-- фисташка -->
    <Color x:Key="Color.Chart4">#7BA4B5</Color>   <!-- голубой -->
    <Color x:Key="Color.Chart5">#D4A843</Color>   <!-- горчица -->
    <Color x:Key="Color.ChartArea">#E6F0E6</Color> <!-- светлая область -->

    <!-- ===================== -->
    <!-- ⚫ NEUTRALS (Теплые серые, а не холодные) -->
    <!-- ===================== -->
    <Color x:Key="Color.Neutral50">#F8FAF5</Color>
    <Color x:Key="Color.Neutral100">#F0F4EC</Color>
    <Color x:Key="Color.Neutral200">#E3EAD8</Color>
    <Color x:Key="Color.Neutral300">#D0DBC0</Color>
    <Color x:Key="Color.Neutral400">#B2C29A</Color>
    <Color x:Key="Color.Neutral500">#8FA373</Color>
    <Color x:Key="Color.Neutral600">#6B8050</Color>
    <Color x:Key="Color.Neutral700">#4D6036</Color>
    <Color x:Key="Color.Neutral800">#334020</Color>
    <Color x:Key="Color.Neutral900">#1A2E0F</Color>

    <!-- ===================== -->
    <!-- 🖌️ BRUSHES -->
    <!-- ===================== -->

    <!-- Background -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource Color.SurfaceHover}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource Color.TextMuted}"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource Color.TextInverse}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Color.Divider}"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource Color.PrimaryHover}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource Color.PrimaryLight}"/>

    <!-- Secondary -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Color.Secondary}"/>
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource Color.SecondaryLight}"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Color.Error}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Color.Info}"/>
    
    <!-- Дополнительные кисти для производства -->
    <SolidColorBrush x:Key="ProductionBrush" Color="{StaticResource Color.Production}"/>
    <SolidColorBrush x:Key="ProductionLightBrush" Color="{StaticResource Color.ProductionLight}"/>
    
    <SolidColorBrush x:Key="ThreadBrush" Color="{StaticResource Color.Thread}"/>
    <SolidColorBrush x:Key="ThreadLightBrush" Color="{StaticResource Color.ThreadLight}"/>

    <!-- Кисти для графиков -->
    <SolidColorBrush x:Key="Chart1Brush" Color="{StaticResource Color.Chart1}"/>
    <SolidColorBrush x:Key="Chart2Brush" Color="{StaticResource Color.Chart2}"/>
    <SolidColorBrush x:Key="Chart3Brush" Color="{StaticResource Color.Chart3}"/>
    <SolidColorBrush x:Key="Chart4Brush" Color="{StaticResource Color.Chart4}"/>
    <SolidColorBrush x:Key="Chart5Brush" Color="{StaticResource Color.Chart5}"/>
    <SolidColorBrush x:Key="ChartAreaBrush" Color="{StaticResource Color.ChartArea}"/>

    <!-- Spacing / radius -->
    <x:Double x:Key="Radius.S">8</x:Double>
    <x:Double x:Key="Radius.M">10</x:Double>
    <x:Double x:Key="Radius.L">14</x:Double>

    <Thickness x:Key="Spacing.XS">4</Thickness>
    <Thickness x:Key="Spacing.S">8</Thickness>
    <Thickness x:Key="Spacing.M">12</Thickness>
    <Thickness x:Key="Spacing.L">16</Thickness>
    <Thickness x:Key="Spacing.XL">20</Thickness>
    <Thickness x:Key="Spacing.CardPadding">12</Thickness>
    
</ResourceDictionary>
